generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum PrayerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum ScheduleType {
  MASS
  CONFESSION
  ADORATION
  OFFICE
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String?
  fullName       String
  isActive       Boolean     @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  roles          UserRole[]
  authoredPosts  Post[]      @relation("PostAuthor")
  authoredEvents Event[]     @relation("EventAuthor")
  auditLogs      AuditLog[]
}

model Role {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userRoles   UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model SiteSetting {
  id             String   @id @default(cuid())
  siteName       String
  legalName      String?
  tagline        String?
  primaryColor   String?  @db.VarChar(20)
  secondaryColor String?  @db.VarChar(20)
  accentColor    String?  @db.VarChar(20)
  logoMediaId    String?
  contactEmail   String?
  contactPhone   String?
  whatsapp       String?
  address        String?
  city           String?
  province       String?
  country        String?  @default("AR")
  postalCode     String?
  latitude       Decimal? @db.Decimal(9, 6)
  longitude      Decimal? @db.Decimal(9, 6)
  youtubeUrl     String?
  instagramUrl   String?
  facebookUrl    String?
  xUrl           String?
  livestreamEnabled Boolean @default(false)
  donationsEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Page {
  id               String            @id @default(cuid())
  title            String
  slug             String            @unique
  excerpt          String?
  contentHtml      String?
  contentJson      Json?
  seoTitle         String?
  seoDescription   String?
  status           PublicationStatus @default(DRAFT)
  isSystemPage     Boolean           @default(false)
  publishedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  @@index([status, publishedAt])
}

model Schedule {
  id             String       @id @default(cuid())
  type           ScheduleType
  title          String?
  weekday        Int          // 0-6
  startTime      String       @db.VarChar(5) // HH:mm
  endTime        String?      @db.VarChar(5)
  locationLabel  String?
  notes          String?
  isActive       Boolean      @default(true)
  validFrom      DateTime?
  validTo        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@index([type, weekday, isActive])
  @@index([validFrom, validTo])
}

model Sacrament {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  shortDescription String?
  descriptionHtml String?
  iconName       String?
  heroMediaId    String?
  status         PublicationStatus @default(PUBLISHED)
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  requirements   SacramentRequirement[]

  @@index([status, sortOrder])
}

model SacramentRequirement {
  id           String   @id @default(cuid())
  sacramentId  String
  title        String
  description  String?
  sortOrder    Int      @default(0)
  isRequired   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sacrament    Sacrament @relation(fields: [sacramentId], references: [id], onDelete: Cascade)

  @@index([sacramentId, sortOrder])
}

model EventCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  color       String?  @db.VarChar(20)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model Event {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt         String?
  descriptionHtml String?
  startsAt        DateTime
  endsAt          DateTime?
  allDay          Boolean           @default(false)
  locationLabel   String?
  address         String?
  categoryId      String?
  heroMediaId     String?
  featured        Boolean           @default(false)
  status          PublicationStatus @default(DRAFT)
  authorId        String?
  publishedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  category        EventCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author          User?             @relation("EventAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([startsAt, status])
  @@index([featured, startsAt])
}

model Ministry {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  shortDescription String?
  descriptionHtml String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  meetingInfo    String?
  status         PublicationStatus @default(PUBLISHED)
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  @@index([status, sortOrder])
}

model PostCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

model Post {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt         String?
  contentHtml     String?
  coverMediaId    String?
  categoryId      String?
  authorId        String?
  status          PublicationStatus @default(DRAFT)
  featured        Boolean           @default(false)
  publishedAt     DateTime?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  category        PostCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author          User?             @relation("PostAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([categoryId, status])
}

model Media {
  id            String   @id @default(cuid())
  fileName      String
  originalName  String?
  mimeType      String
  sizeBytes     Int
  width         Int?
  height        Int?
  altText       String?
  title         String?
  storageKey    String   @unique
  publicUrl     String
  folder        String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([folder, createdAt])
}

model PrayerRequest {
  id             String             @id @default(cuid())
  fullName       String?
  email          String?
  intention      String
  isAnonymous    Boolean            @default(false)
  allowContact   Boolean            @default(false)
  status         PrayerRequestStatus @default(PENDING)
  ipHash         String?
  userAgent      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reviewedAt     DateTime?
  deletedAt      DateTime?

  @@index([status, createdAt])
}

model ContactMessage {
  id            String        @id @default(cuid())
  fullName      String
  email         String
  phone         String?
  subject       String?
  message       String
  status        MessageStatus @default(NEW)
  ipHash        String?
  userAgent     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  repliedAt     DateTime?
  deletedAt     DateTime?

  @@index([status, createdAt])
}

model Volunteer {
  id              String        @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  interests       String?
  availability    String?
  notes           String?
  status          MessageStatus @default(NEW)
  ipHash          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  @@index([status, createdAt])
}

model Donation {
  id              String         @id @default(cuid())
  donorName       String?
  donorEmail      String?
  amountCents     Int
  currency        String         @default("ARS") @db.VarChar(3)
  provider        String?
  providerRef     String?        @unique
  status          DonationStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Faq {
  id             String            @id @default(cuid())
  question       String
  answerHtml     String
  category       String?
  sortOrder      Int               @default(0)
  status         PublicationStatus @default(PUBLISHED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  @@index([status, sortOrder])
}

model Testimonial {
  id             String            @id @default(cuid())
  fullName       String
  roleLabel      String?
  quote          String
  status         PublicationStatus @default(DRAFT)
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
}

model LivestreamLink {
  id            String   @id @default(cuid())
  platform      String
  title         String
  url           String
  isActive      Boolean  @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, startsAt])
}

model LiturgicalCalendarNote {
  id            String   @id @default(cuid())
  noteDate      DateTime
  title         String
  description   String?
  color         String?  @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([noteDate])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  entity       String
  entityId     String?
  action       String
  before       Json?
  after        Json?
  ipHash       String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId, createdAt])
  @@index([userId, createdAt])
}
